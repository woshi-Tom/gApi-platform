# gAPI Platform - Environment Configuration Template
# Copy this file to .env and fill in your values
# Usage: docker-compose --env-file .env up -d

# ===================
# Database Configuration
# ===================
POSTGRES_USER=gapi
POSTGRES_PASSWORD=CHANGE_ME_generate_strong_password
POSTGRES_DB=gapi

# ===================
# Redis Configuration
# ===================
REDIS_PASSWORD=CHANGE_ME_generate_strong_password

# ===================
# RabbitMQ Configuration
# ===================
RABBITMQ_USER=gapi
RABBITMQ_PASSWORD=CHANGE_ME_generate_strong_password

# ===================
# Security Secrets (CRITICAL - CHANGE IN PRODUCTION)
# ===================
# JWT Secret - Must be at least 32 characters
JWT_SECRET=CHANGE_ME_use_at_least_32_characters_long_secret_key

# ===================
# Application URLs
# ===================
FRONTEND_URL=http://localhost

# ===================
# Payment Integration (Optional)
# ===================
GAPI_ALIPAY_ENABLED=false
GAPI_ALIPAY_SANDBOX=true
# GAPI_ALIPAY_APP_ID=
# GAPI_ALIPAY_PRIVATE_KEY=
# GAPI_ALIPAY_PUBLIC_KEY=
