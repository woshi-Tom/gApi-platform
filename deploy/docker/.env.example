# Database
POSTGRES_DB=gapi
POSTGRES_USER=gapi
POSTGRES_PASSWORD=gapi123

# Redis
REDIS_PASSWORD=redis123

# Backend
GAPI_SERVER_PORT=8080
GAPI_MODE=debug
GAPI_JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters
GAPI_ADMIN_SECRET=gapi-admin-secret-key-2026

# Frontend
VITE_API_BASE_URL=http://localhost:8080

# Alipay Sandbox (沙箱模式)
# 前往 https://open.alipay.com/develop/sandbox/app 获取沙箱参数
GAPI_ALIPAY_ENABLED=true
GAPI_ALIPAY_SANDBOX=true
GAPI_ALIPAY_APP_ID=沙箱APPID
GAPI_ALIPAY_PRIVATE_KEY=沙箱应用私钥(RSA2)
GAPI_ALIPAY_PUBLIC_KEY=沙箱支付宝公钥
