# gAPI Platform Environment Configuration Template
# Copy this file to .env and fill in your values

# ===================
# Database Configuration
# ===================
DB_USER=gapi
DB_PASSWORD=CHANGE_ME_generate_strong_password
DB_NAME=gapi

# ===================
# Redis Configuration
# ===================
REDIS_PASSWORD=CHANGE_ME_generate_strong_password

# ===================
# RabbitMQ Configuration
# ===================
RABBITMQ_USER=gapi
RABBITMQ_PASSWORD=CHANGE_ME_generate_strong_password

# ===================
# Security Secrets (CRITICAL)
# ===================
# JWT Secret - Must be at least 32 characters
JWT_SECRET=CHANGE_ME_use_at_least_32_characters_long_secret_key

# Admin Secret - Used for admin panel access
ADMIN_SECRET=CHANGE_ME_generate_random_admin_secret

# ===================
# Application URLs
# ===================
FRONTEND_URL=http://localhost

# ===================
# Payment Integration (Optional)
# ===================
# Alipay
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# WeChat Pay
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=

# ===================
# SMTP Email (Optional)
# ===================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
